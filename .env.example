# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_... (for admin scripts only, never expose to client!)

# Anthropic (Claude Haiku for AI-enhanced friction assessment, optional)
ANTHROPIC_API_KEY=sk-ant-...

# Open-Meteo (no key needed, but included for future config)
# OPEN_METEO_URL=https://api.open-meteo.com/v1

# Resend (for sending sync key emails)
RESEND_API_KEY=re_your-api-key-here

# Windy Webcams API
WINDY_API_KEY=your-windy-api-key

# Debugging (client-side render logs)
# Set to 1 to enable console logs for renders and tab switch timings
# Do not enable in production
# NEXT_PUBLIC_DEBUG_RENDERS=1
